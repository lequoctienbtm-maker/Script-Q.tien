local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = game:GetService("Workspace").CurrentCamera
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Config = {
	Aim = false,
	Kill = false,
	Esp = false
}
local CanShoot = true
local function IsVisible(TargetPart)
	local RaycastParams = RaycastParams.new()
	RaycastParams.FilterDescendantsInstances = {
		LocalPlayer.Character,
		TargetPart.Parent
	}
	RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
	local RaycastResult = workspace:Raycast(Camera.CFrame.Position, TargetPart.Position - Camera.CFrame.Position, RaycastParams)
	return not RaycastResult
end
local function UpdateESP()
	for _, Player in pairs(Players:GetPlayers()) do
		if Player ~= LocalPlayer and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
			local root = Player.Character.HumanoidRootPart
			local espBox = root:FindFirstChild("Q_Tien_Box")
			if Config.Esp and Player.Character:FindFirstChildOfClass("Humanoid") and Player.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
				if not espBox then
					espBox = Instance.new("BoxHandleAdornment", root)
					espBox.Name = "Q_Tien_Box";
					espBox.Size = Vector3.new(4, 5, 1)
					espBox.Color3 = Color3.fromRGB(0, 255, 255);
					espBox.AlwaysOnTop = true
					espBox.ZIndex = 5;
					espBox.Adornee = root;
					espBox.Transparency = 0.3
				end
			elseif espBox then
				espBox:Destroy()
			end
		end
	end
end
RunService.Heartbeat:Connect(function()
	UpdateESP()
	if not Config.Aim and not Config.Kill then
		return
	end
	local Target = nil;
	local ShortestDist = math.huge
	for _, Player in pairs(Players:GetPlayers()) do
		if Player ~= LocalPlayer and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
			local Head = Player.Character:FindFirstChild("Head")
			if Head and IsVisible(Head) then
				local Dist = (Head.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
				if Dist < ShortestDist then
					ShortestDist = Dist;
					Target = Player
				end
			end
		end
	end
	if Target and Target.Character:FindFirstChild("Head") then
		local Head = Target.Character.Head
		if Config.Aim then
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, Head.Position)
		elseif Config.Kill then
			local HRP = Target.Character.HumanoidRootPart
			LocalPlayer.Character.HumanoidRootPart.CFrame = HRP.CFrame * CFrame.new(0, 0, 2) * CFrame.Angles(0, math.pi, 0)
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, Head.Position)
			if CanShoot then
				CanShoot = false;
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
				task.wait(0.05);
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
				task.wait(0.05);
				CanShoot = true
			end
		end
	end
end)
